# Flag Explorer 2026 — CI lane: build the Capacitor iOS app and push to TestFlight.
# Auth is App Store Connect API key only (no Apple ID / 2FA needed on CI).
# Signing is Xcode cloud-managed via -allowProvisioningUpdates.

default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    key_path = File.absolute_path("asc_api_key.p8")
    File.write(key_path, ENV.fetch("ASC_KEY_P8"))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )

    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: true,
      team_id: ENV.fetch("APPLE_TEAM_ID")
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{key_path}",
        "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')}",
        "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}",
        "CURRENT_PROJECT_VERSION=#{ENV.fetch('GITHUB_RUN_NUMBER', '1')}"
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
