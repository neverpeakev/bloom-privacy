# Flag Explorer 2026 — CI lane: build the Capacitor iOS app and push to TestFlight.
# Auth is App Store Connect API key only (no Apple ID / 2FA needed on CI).
# Signing is Xcode cloud-managed via -allowProvisioningUpdates.

default_platform(:ios)

require "base64"

# Rebuild a clean PEM no matter how the .p8 was pasted into the secret:
# with real newlines, with literal "\n", flattened onto one line, or as
# base64 of the whole file. OpenSSL is strict; paste formats are not.
def normalized_p8(raw)
  s = raw.strip.gsub('\n', "\n")
  compact = s.gsub(/\s+/, "")               # whitespace-free form, reused below
  unless s.include?("BEGIN PRIVATE KEY")
    decoded = (Base64.decode64(compact) rescue "")
    s = decoded if decoded.include?("BEGIN PRIVATE KEY")
  end
  body = s[/BEGIN PRIVATE KEY-----(.*?)-----END/m, 1]
  # headerless paste: the secret is just the PEM's base64 body
  body ||= s if compact.match?(%r{\A[A-Za-z0-9+/]+={0,2}\z})
  UI.user_error!("ASC_KEY_P8 secret doesn't contain a .p8 private key — paste the full contents of the AuthKey_XXXX.p8 file") unless body
  "-----BEGIN PRIVATE KEY-----\n#{body.gsub(/\s+/, '').scan(/.{1,64}/).join("\n")}\n-----END PRIVATE KEY-----\n"
end

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    key_path = File.absolute_path("asc_api_key.p8")
    File.write(key_path, normalized_p8(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )

    update_code_signing_settings(
      path: "ios/App/App.xcodeproj",
      use_automatic_signing: true,
      team_id: ENV.fetch("APPLE_TEAM_ID")
    )

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      output_directory: "build",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath #{key_path}",
        "-authenticationKeyID #{ENV.fetch('ASC_KEY_ID')}",
        "-authenticationKeyIssuerID #{ENV.fetch('ASC_ISSUER_ID')}",
        "CURRENT_PROJECT_VERSION=#{ENV.fetch('GITHUB_RUN_NUMBER', '1')}"
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Upload listing metadata + screenshots and submit for App Store review"
  lane :release do
    key_path = File.absolute_path("asc_api_key.p8")
    File.write(key_path, normalized_p8(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )

    deliver(
      api_key: api_key,
      force: true,                       # no interactive HTML preview
      skip_binary_upload: true,          # binary already shipped by the beta lane
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false,
      automatic_release: true,
      submit_for_review: true,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false
      }
    )
  end

  desc "Upload screenshots only (skips metadata to dodge fastlane's first-version 'No data' bug)"
  lane :screenshots do
    key_path = File.absolute_path("asc_api_key.p8")
    File.write(key_path, normalized_p8(ENV.fetch("ASC_KEY_P8")))

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path
    )

    deliver(
      api_key: api_key,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,               # avoids the review_attachment crash
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false
    )
  end
end

platform :ios do
  desc "Print the current App Store review status"
  lane :status do
    key_path = File.absolute_path("asc_api_key.p8")
    File.write(key_path, normalized_p8(ENV.fetch("ASC_KEY_P8")))
    app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: key_path,
      set_spaceship_token: true
    )
    app = Spaceship::ConnectAPI::App.find("com.neverpeak.flagexplorer")
    UI.user_error!("App not found") unless app
    versions = app.get_app_store_versions(filter: { platform: "IOS" })
    versions.sort_by(&:version_string).each do |v|
      UI.message("WORLDCOPA_STATUS version=#{v.version_string} state=#{v.app_store_state}")
    end
  end
end
